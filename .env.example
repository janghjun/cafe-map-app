# 카공 어디가? 인천편 — 환경 변수 예시
# 실제 키를 이 파일에 넣지 마세요. 이 파일은 Git에 커밋됩니다.
# 실제 값은 .env 또는 Vercel 프로젝트 설정에서 관리하세요.

# Supabase 프로젝트 URL (예: https://abcdefghij.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url_here

# Supabase anon (public) key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 데이터 소스 선택: "mock" | "supabase"
# - mock: 개발용 더미 데이터 사용 (기본값, 환경 변수 없어도 동작)
# - supabase: Supabase에서 실시간 데이터 로드
VITE_DATA_SOURCE=mock

# ────────────────────────────────────────────────
# 서버 사이드 전용 (scripts/ 에서만 사용)
# ⚠️ VITE_ 접두사 없이 사용하세요 — 클라이언트 번들에 포함 금지
# ────────────────────────────────────────────────

# 네이버 개발자 센터 검색 API
# https://developers.naver.com/apps/
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# ────────────────────────────────────────────────
# 관리자 화면 비밀번호 (?mode=admin 진입 시 요구)
# ⚠️ Vite 번들에 포함됩니다 — 강력한 무작위 문자열을 사용하세요.
# ⚠️ 이 값이 노출되면 관리자 화면에 누구나 접근할 수 있습니다.
VITE_ADMIN_PASSWORD=your_admin_password_here

# ────────────────────────────────────────────────
# 서버 사이드 키 (scripts/ 전용 — 클라이언트 노출 금지)
# Supabase 대시보드 → Settings → API → service_role key
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
